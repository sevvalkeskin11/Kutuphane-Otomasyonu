# Option 1 (Supabase Postgres): use direct connection string
SUPABASE_DB_URL=postgresql://postgres.cshpybbrjpiespcmagda:KutuphaneSS1.@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=no-verify

# Option 2 (classic pg vars)
# PGUSER=postgres
# PGPASSWORD=
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=KutuphaneOtomasyon

# Optional: enables Google Books cover lookup endpoint
# GOOGLE_BOOKS_API_KEY=

# Optional: set false only for local non-SSL Postgres
# PG_SSL=true

# Optional: backend port (default 5050)
# PORT=5050

# Optional: JWT-like token secret for auth endpoints (/api/auth/*)
# AUTH_SECRET=change-this-before-production

# Optional: token lifetime in hours (default 168 = 7 days)
# TOKEN_EXPIRES_HOURS=168

# Optional: comma-separated frontend origins for CORS
# CORS_ORIGIN=http://localhost:5173

# Optional: default due date for borrow requests (days)
# DEFAULT_BORROW_DAYS=14

# Optional: if true, /api/odunc can auto-pick a user when no token exists
# ALLOW_GUEST_BORROW=true
